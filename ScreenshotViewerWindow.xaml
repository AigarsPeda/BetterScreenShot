<Window x:Class="BetterScreenShot.ScreenshotViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screenshot Viewer"
        Width="1000"
        Height="700"
        MinWidth="520"
        MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ViewerPageBackgroundBrush}"
        Foreground="{DynamicResource ViewerPrimaryTextBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="ViewerPageBackgroundBrush" Color="#F7F9FC" />
        <SolidColorBrush x:Key="ViewerSurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ViewerSurfaceBorderBrush" Color="#D8E1EC" />
        <SolidColorBrush x:Key="ViewerSurfaceHoverBrush" Color="#F5F9FD" />
        <SolidColorBrush x:Key="ViewerSurfacePressedBrush" Color="#EEF4FB" />
        <SolidColorBrush x:Key="ViewerPrimaryTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="ViewerSecondaryTextBrush" Color="#415063" />
        <SolidColorBrush x:Key="ViewerCanvasBrush" Color="#EDEFF4" />

        <Style x:Key="ViewerLucideStrokeStyle" TargetType="Shape">
            <Setter Property="Stroke" Value="{DynamicResource ViewerPrimaryTextBrush}" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="ViewerActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource ViewerSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ViewerSurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource ViewerPrimaryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ViewerSurfaceHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ViewerSurfacePressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource ViewerPageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="16,16,16,12"
                Padding="0"
                Background="Transparent">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        Style="{StaticResource ViewerActionButtonStyle}"
                        VerticalAlignment="Top"
                        Click="SaveAsButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="18"
                                 Height="18"
                                 Margin="0,0,8,0">
                            <Canvas Width="24" Height="24">
                                <Path Style="{StaticResource ViewerLucideStrokeStyle}"
                                      Data="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z" />
                                <Path Style="{StaticResource ViewerLucideStrokeStyle}"
                                      Data="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7" />
                                <Path Style="{StaticResource ViewerLucideStrokeStyle}"
                                      Data="M7 3v4a1 1 0 0 0 1 1h7" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ViewerPrimaryTextBrush}"
                                   Text="Save As" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="3"
                        Style="{StaticResource ViewerActionButtonStyle}"
                        VerticalAlignment="Top"
                        Click="DeleteButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="18"
                                 Height="18"
                                 Margin="0,0,8,0">
                            <Canvas Width="24" Height="24">
                                <Path Style="{StaticResource ViewerLucideStrokeStyle}"
                                      Data="M10 11v6" />
                                <Path Style="{StaticResource ViewerLucideStrokeStyle}"
                                      Data="M14 11v6" />
                                <Path Style="{StaticResource ViewerLucideStrokeStyle}"
                                      Data="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6" />
                                <Path Style="{StaticResource ViewerLucideStrokeStyle}"
                                      Data="M3 6h18" />
                                <Path Style="{StaticResource ViewerLucideStrokeStyle}"
                                      Data="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ViewerPrimaryTextBrush}"
                                   Text="Delete" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="16,0,16,16"
                Background="{DynamicResource ViewerCanvasBrush}"
                BorderBrush="{DynamicResource ViewerSurfaceBorderBrush}"
                BorderThickness="1"
                CornerRadius="20"
                ClipToBounds="True">
            <Grid>
                <Image Name="ViewerImage"
                       Margin="16"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="HighQuality" />
            </Grid>
        </Border>
    </Grid>
</Window>
