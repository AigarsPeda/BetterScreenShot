<Window x:Class="BetterScreenShot.ScreenshotToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screenshot Saved"
        Width="300"
        Height="170"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        AllowsTransparency="True">
    <Window.Resources>
        <Style x:Key="LucideStrokeStyle" TargetType="Shape">
            <Setter Property="Stroke" Value="White" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="CommandButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#D91B1B1B" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="0"
                                      Color="#66000000"
                                      Opacity="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2272727" />
                    <Setter Property="BorderBrush" Value="#66FFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF141414" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#B0151515" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D0222222" />
                    <Setter Property="BorderBrush" Value="#66FFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#F00F0F0F" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Grid" x:Key="HoverOverlayStyle">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=PreviewBorder, Path=IsMouseOver}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CornerActionButtonStyle" TargetType="Button" BasedOn="{StaticResource CloseButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,10,10,10" />
        </Style>

        <Style TargetType="Button" x:Key="HoverCornerActionStyle" BasedOn="{StaticResource CornerActionButtonStyle}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=PreviewBorder, Path=IsMouseOver}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="HoverCloseStyle" BasedOn="{StaticResource HoverCornerActionStyle}">
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style TargetType="Button" x:Key="HoverPreviewStyle" BasedOn="{StaticResource HoverCornerActionStyle}">
            <Setter Property="VerticalAlignment" Value="Bottom" />
        </Style>

        <Style x:Key="IconTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border Name="PreviewBorder"
            Background="#FF0E0E0E"
            CornerRadius="20"
            BorderBrush="#22000000"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Grid ClipToBounds="True">
            <Image Name="PreviewImage"
                   Stretch="UniformToFill" />

            <Grid Style="{StaticResource HoverOverlayStyle}">
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#33000000" Offset="0" />
                            <GradientStop Color="#66000000" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource CommandButtonStyle}"
                            Margin="0,0,12,0"
                            Click="CopyButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="18"
                                     Height="18"
                                     Margin="0,0,8,0">
                                <Canvas Width="24" Height="24">
                                    <Rectangle Style="{StaticResource LucideStrokeStyle}"
                                               Width="14"
                                               Height="14"
                                               RadiusX="2"
                                               RadiusY="2"
                                               Canvas.Left="8"
                                               Canvas.Top="8" />
                                    <Path Style="{StaticResource LucideStrokeStyle}"
                                          Data="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Style="{StaticResource IconTextStyle}"
                                       Text="Copy" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource CommandButtonStyle}"
                            Click="SaveButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="18"
                                     Height="18"
                                     Margin="0,0,8,0">
                                <Canvas Width="24" Height="24">
                                    <Path Style="{StaticResource LucideStrokeStyle}"
                                          Data="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z" />
                                    <Path Style="{StaticResource LucideStrokeStyle}"
                                          Data="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7" />
                                    <Path Style="{StaticResource LucideStrokeStyle}"
                                          Data="M7 3v4a1 1 0 0 0 1 1h7" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Style="{StaticResource IconTextStyle}"
                                       Text="Save" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Button Style="{StaticResource HoverCloseStyle}"
                    Click="CloseButton_Click">
                <Viewbox Width="16" Height="16">
                    <Canvas Width="24" Height="24">
                        <Path Style="{StaticResource LucideStrokeStyle}"
                              Data="M18 6 6 18" />
                        <Path Style="{StaticResource LucideStrokeStyle}"
                              Data="M6 6 18 18" />
                    </Canvas>
                </Viewbox>
            </Button>

            <Button Style="{StaticResource HoverPreviewStyle}"
                    Click="PreviewButton_Click">
                <Viewbox Width="16" Height="16">
                    <Canvas Width="24" Height="24">
                        <Path Style="{StaticResource LucideStrokeStyle}"
                              Data="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z" />
                        <Path Style="{StaticResource LucideStrokeStyle}"
                              Data="M15 5 19 9" />
                    </Canvas>
                </Viewbox>
            </Button>
        </Grid>
    </Border>
</Window>
