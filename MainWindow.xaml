<Window x:Class="BetterScreenShot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Better ScreenShot"
        Height="260"
        Width="420"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock
                Text="Better ScreenShot"
                FontSize="24"
                FontWeight="SemiBold"
                Margin="0,0,0,16" />
            <Button
                Name="CaptureButton"
                Content="Capture Full Screen"
                Height="40"
                Margin="0,0,0,12"
                Click="CaptureButton_Click" />
            <Button
                Name="SelectAreaButton"
                Content="Select Area"
                Height="40"
                Click="SelectAreaButton_Click" />
            <TextBlock
                Name="StatusText"
                Margin="0,16,0,0"
                Text="Ready"
                TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
