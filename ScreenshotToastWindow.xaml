<Window x:Class="BetterScreenShot.ScreenshotToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screenshot Saved"
        Width="340"
        Height="160"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        AllowsTransparency="True">
    <Border Background="#FF1B1B1B"
            CornerRadius="16"
            Padding="14"
            BorderBrush="#FF2F2F2F"
            BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="96" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    CornerRadius="10"
                    ClipToBounds="True"
                    Background="#FF101010">
                <Image Name="PreviewImage"
                       Stretch="UniformToFill" />
            </Border>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Screenshot saved"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <TextBlock Name="PathText"
                           Margin="0,6,0,12"
                           Foreground="#FFB8B8B8"
                           FontSize="12"
                           TextWrapping="Wrap"
                           MaxHeight="36" />
                <StackPanel Orientation="Horizontal">
                    <Button Name="OpenButton"
                            Width="68"
                            Height="30"
                            Margin="0,0,8,0"
                            Content="Open"
                            Click="OpenButton_Click" />
                    <Button Name="DeleteButton"
                            Width="68"
                            Height="30"
                            Margin="0,0,8,0"
                            Content="Delete"
                            Click="DeleteButton_Click" />
                    <Button Width="68"
                            Height="30"
                            Content="Close"
                            Click="CloseButton_Click" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
