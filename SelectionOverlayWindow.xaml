<Window x:Class="BetterScreenShot.SelectionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Cursor="Cross"
        KeyDown="Window_KeyDown">
    <Canvas Name="OverlayCanvas"
            Background="Transparent"
            MouseLeftButtonDown="OverlayCanvas_MouseLeftButtonDown"
            MouseMove="OverlayCanvas_MouseMove"
            MouseLeftButtonUp="OverlayCanvas_MouseLeftButtonUp">
        <Rectangle Name="TopMask" Fill="#66000000" />
        <Rectangle Name="LeftMask" Fill="#66000000" />
        <Rectangle Name="RightMask" Fill="#66000000" />
        <Rectangle Name="BottomMask" Fill="#66000000" />
        <Rectangle Name="SelectionRectangle"
                   Visibility="Collapsed"
                   Stroke="#FF5CC8FF"
                   StrokeThickness="2"
                   Fill="#12FFFFFF" />
        <Border Name="InstructionBadge"
                Canvas.Left="24"
                Canvas.Top="24"
                Background="#AA111111"
                CornerRadius="8"
                Padding="12,8">
            <TextBlock Foreground="White"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Text="Drag to select an area. Press Esc to cancel." />
        </Border>
    </Canvas>
</Window>
