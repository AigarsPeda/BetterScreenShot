<Window x:Class="BetterScreenShot.ScreenshotToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screenshot Saved"
        Width="400"
        Height="230"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        AllowsTransparency="True">
    <Window.Resources>
        <Style x:Key="CommandButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#D91B1B1B" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="0"
                                      Color="#66000000"
                                      Opacity="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2272727" />
                    <Setter Property="BorderBrush" Value="#66FFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF141414" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#B0151515" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D0222222" />
                    <Setter Property="BorderBrush" Value="#66FFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#F00F0F0F" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Grid" x:Key="HoverOverlayStyle">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=PreviewBorder, Path=IsMouseOver}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="HoverCloseStyle" BasedOn="{StaticResource CloseButtonStyle}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=PreviewBorder, Path=IsMouseOver}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border Name="PreviewBorder"
            Background="#FF0E0E0E"
            CornerRadius="20"
            BorderBrush="#22000000"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Grid ClipToBounds="True">
            <Image Name="PreviewImage"
                   Stretch="UniformToFill" />

            <Grid Style="{StaticResource HoverOverlayStyle}">
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#33000000" Offset="0" />
                            <GradientStop Color="#66000000" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource CommandButtonStyle}"
                            Margin="0,0,12,0"
                            Click="CopyButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="15"
                                       Margin="0,0,8,0"
                                       Style="{StaticResource IconTextStyle}"
                                       Text="&#xE8C8;" />
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Style="{StaticResource IconTextStyle}"
                                       Text="Copy" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource CommandButtonStyle}"
                            Click="SaveButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="15"
                                       Margin="0,0,8,0"
                                       Style="{StaticResource IconTextStyle}"
                                       Text="&#xE74E;" />
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Style="{StaticResource IconTextStyle}"
                                       Text="Save" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,10,10,0"
                    Width="34"
                    Height="34"
                    Style="{StaticResource HoverCloseStyle}"
                    Click="CloseButton_Click">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="13"
                           Foreground="White"
                           Text="&#xE711;" />
            </Button>
        </Grid>
    </Border>
</Window>
